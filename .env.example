# Sécurité
MAX_DAILY_TRADES=50
EMERGENCY_STOP_LOSS=500

# Notifications
NOTIFY_TRADES=True
SAVE_LOGS=True
SHOW_PERFORMANCE=True

# Backtest
BACKTEST_ENABLED=False
