# ===== CLÉS API BINANCE =====
BINANCE_API_KEY=votre_cle_api_ici
BINANCE_API_SECRET=votre_cle_secrete_ici
TESTNET=False

# ===== TRADING =====
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
STRATEGY_TYPE=intelligent
ORDER_TYPE=adaptive
TRADE_AMOUNT=5
CHECK_INTERVAL=5
REALTIME_TRADING=True

# ===== GESTION DES RISQUES =====
MAX_DAILY_LOSS=200
STOP_LOSS_PERCENT=5
TRAILING_STOP_PERCENT=3
MAX_POSITION_SIZE=50
RISK_PER_TRADE=2
MAX_DAILY_TRADES=100
EMERGENCY_STOP_LOSS=500

# ===== FRAIS BINANCE =====
TRADING_FEE_PERCENT=0.1
MIN_PROFIT_THRESHOLD=0.8

# ===== BACKTESTING =====
BACKTEST_ENABLED=False
BACKTEST_DAYS=30
BACKTEST_SYMBOL=BTCUSDT

# ===== PAPER TRADING =====
PAPER_TRADING=False
PAPER_BALANCE=1000

# ===== BINANCE EARN (TIRELIRE) =====
ENABLE_EARN=True
MIN_TRADING_BALANCE=5
EARN_ALLOCATION_PERCENT=100
FLEXIBLE_SAVINGS_THRESHOLD=0.01
LOCKED_STAKING_THRESHOLD=50
EARN_WITHDRAW_THRESHOLD=5

# ===== GESTION SOLDE =====
# True = Utilise tout le solde disponible (monopolise 1 crypto)
# False = Utilise montant fixe basé sur TRADE_AMOUNT (permet multi-crypto)
USE_FULL_BALANCE=False
# Si USE_FULL_BALANCE=True, % maximum du solde à utiliser par trade
MAX_BALANCE_PER_TRADE=50

# ===== POSITIONS BLOQUÉES =====
MAX_STUCK_LOSS=15
STUCK_THRESHOLD_HOURS=24

# ===== SÉLECTION CRYPTOS =====
MIN_CRYPTO_SCORE=40
MAX_TRADEABLE_CRYPTOS=2

# ===== TIRELIRE =====
TIRELIRE_MODE=True

# ===== MONITORING =====
LOG_LEVEL=INFO
SAVE_LOGS=True
SHOW_PERFORMANCE=True
ALERT_ON_LOSS=True

# ===== NOTIFICATIONS TELEGRAM =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_TRADES=True
NOTIFY_ERRORS=True

# ===== OPTIMISATIONS =====
ENABLE_LATENCY_OPTIMIZER=True
PARALLEL_WORKERS=10
WS_PURE_MODE=True
EVENT_DRIVEN=True
MIN_PRICE_CHANGE=0.005
DEBOUNCE_TIME=2

# ===== SYNCHRONISATION =====
# Force le rafraîchissement des balances à chaque cycle (détecte dépôts instantanément)
FORCE_BALANCE_REFRESH=True
# Intervalle de vérification du portefeuille Funding (en secondes) - Transfert auto vers Spot
FUNDING_CHECK_INTERVAL=300

# ===== AFFICHAGE =====
SHOW_DECISIONS=True
SHOW_DECISION_DETAILS=True

# ===== NOTIFICATIONS PÉRIODIQUES =====
TELEGRAM_STATUS_INTERVAL=3600