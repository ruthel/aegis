# Template versionné. Copiez ce fichier vers .env.local et mettez vos vrais secrets uniquement là-bas.

# ===== EXCHANGE (binance ou kraken) =====
EXCHANGE=kraken

# ===== CLÉS API BINANCE =====
BINANCE_API_KEY=votre_cle_binance_ici
BINANCE_API_SECRET=votre_secret_binance_ici

# ===== CLÉS API KRAKEN =====
KRAKEN_API_KEY=votre_cle_kraken_ici
KRAKEN_API_SECRET=votre_secret_kraken_ici

TESTNET=False

# ===== TRADING CORE =====
TRADING_PAIRS=BTCUSD,ETHUSD,SOLUSD,ADAUSD
TRADE_AMOUNT=5

# ===== GESTION RISQUES =====
MAX_DAILY_LOSS=50
STOP_LOSS_PERCENT=5
TRAILING_STOP_PERCENT=3
RISK_PER_TRADE=2
MAX_DAILY_TRADES=15
EMERGENCY_STOP_LOSS=500
SYMBOL_COOLDOWN_SECONDS=300
SYMBOL_FAILURE_COOLDOWN_SECONDS=120

# ===== FALLBACKS SÉCURISÉS =====
MAIN_TIMEFRAME=15m
MIN_CONFIDENCE=30
MIN_PROFIT_THRESHOLD=0.8

# ===== PAPER TRADING =====
PAPER_TRADING=False
PAPER_BALANCE=1000

# ===== POSITIONS BLOQUÉES =====
MAX_STUCK_LOSS=15
STUCK_THRESHOLD_HOURS=24

# ===== SÉLECTION CRYPTOS =====
MIN_CRYPTO_SCORE=40

# ===== RÉGIME MARCHÉ / BEAR MODE =====
MARKET_REGIME_FILTER=True
FALLING_KNIFE_FILTER=True
REQUIRE_REVERSAL_CONFIRMATION_IN_BEAR=True
BEAR_MODE_TRADE_MULTIPLIER=0.35
BEAR_MODE_MIN_CONFIDENCE_BONUS=20
BEAR_MODE_SUPPORT_TOUCH_OVERRIDE=False
BEAR_MODE_ALLOWED_PAIRS=BTC/USD,ETH/USD
MARKET_CONTEXT_CACHE_SECONDS=300

# ===== MONITORING =====
LOG_LEVEL=INFO
SAVE_LOGS=True
DECISION_JOURNAL_FILE=data/decision_journal.jsonl
DECISION_JOURNAL_MAX=5000
DASHBOARD_PORT=8080
LIVE_STATUS_FILE=data/live_status.json
LIVE_STATUS_INTERVAL_SECONDS=1

# ===== TELEGRAM =====
BOT_NAME=Aegis
TELEGRAM_BOT_TOKEN=votre_token_telegram
TELEGRAM_CHAT_ID=votre_chat_id
TELEGRAM_STATUS_INTERVAL=1800

# ===== GESTION SOLDE =====
USE_FULL_BALANCE=False
MAX_BALANCE_PER_TRADE=50

# ===== SYNCHRONISATION =====
FORCE_BALANCE_REFRESH=True

# ===== BACKTEST SUPPORT TOUCH PRO =====
BACKTEST_TIMEFRAME=15m
BACKTEST_LIMIT=720
BACKTEST_LOOKBACK=50
BACKTEST_MAX_HOLD_CANDLES=24
BACKTEST_TARGET_PERCENT=1.5
BACKTEST_STOP_PERCENT=1.0
BACKTEST_COOLDOWN_CANDLES=4
SUPPORT_TOUCH_ADAPTIVE_FILTER=True
SUPPORT_TOUCH_BACKTEST_INTERVAL_HOURS=12
SUPPORT_TOUCH_MIN_TRADES=10
SUPPORT_TOUCH_MIN_WINRATE=50
SUPPORT_TOUCH_MIN_TOTAL_PNL=0
SUPPORT_TOUCH_MIN_AVG_PNL=0
SUPPORT_TOUCH_FAIL_CLOSED=True
SUPPORT_TOUCH_BACKTEST_FILE=data/support_touch_backtest.json
SUPPORT_TOUCH_BACKTEST_TIMEOUT_SECONDS=90
